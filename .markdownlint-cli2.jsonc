{
  "config": {
    // Allow longer lines — 80 is too strict for docs with tables and URLs
    "MD013": {
      "line_length": 120,
      "code_blocks": false,
      "tables": false,
      "headings": false
    },
    // Allow bare URLs (common in docs)
    "MD034": false,
    // Allow duplicate headings in siblings (needed for CHANGELOG.md)
    "MD024": { "siblings_only": true },
    // Tables: don't enforce padding style
    "MD060": false
  },
  "ignores": [
    "node_modules",
    "**/node_modules",
    "target",
    "docs/dist",
    ".burin",
    ".claude",
    "docs/src/SUMMARY.md",
    "conformance/tests/**/.harn/**/*.md",
    // qmode experiment writes synthetic profile bullets here during eval runs;
    // these are not docs and shouldn't be linted as such.
    "experiments/**/.harn/**/*.md",
    "experiments/**/USER_PROFILE.md"
  ]
}
