{
  "config": {
    // Allow longer lines — 80 is too strict for docs with tables and URLs
    "MD013": {
      "line_length": 120,
      "code_blocks": false,
      "tables": false,
      "headings": false
    },
    // Allow bare URLs (common in docs)
    "MD034": false,
    // Allow duplicate headings in siblings (needed for CHANGELOG.md)
    "MD024": { "siblings_only": true },
    // Tables: don't enforce padding style
    "MD060": false
  },
  "ignores": ["node_modules", "**/node_modules", "target", ".burin", ".claude", "docs/src/SUMMARY.md"]
}
