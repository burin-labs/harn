/** host_tools. */
pub fn host_tools() {
  return host_tool_list()
}

/** host_tool_lookup. */
pub fn host_tool_lookup(name: string) {
  for entry in host_tool_list() {
    if entry?.name == name {
      return entry
    }
  }
  return nil
}

/** host_tool_available. */
pub fn host_tool_available(name: string) -> bool {
  return host_tool_lookup(name) != nil
}
