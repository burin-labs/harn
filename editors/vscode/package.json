{
  "name": "harn-lang",
  "displayName": "Harn Language",
  "description": "Language support for Harn — the pipeline-oriented language for AI agents",
  "version": "0.1.0",
  "publisher": "burin-labs",
  "repository": {
    "type": "git",
    "url": "https://github.com/burin-labs/harn"
  },
  "categories": ["Programming Languages"],
  "engines": {
    "vscode": "^1.80.0"
  },
  "activationEvents": [
    "onLanguage:harn",
    "onDebug"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "harn",
        "aliases": ["Harn", "harn"],
        "extensions": [".harn"],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "harn-prompt",
        "aliases": ["Harn Prompt", "harn-prompt"],
        "extensions": [".harn.prompt", ".prompt"]
      }
    ],
    "grammars": [
      {
        "language": "harn",
        "scopeName": "source.harn",
        "path": "./syntaxes/harn.tmLanguage.json"
      },
      {
        "language": "harn-prompt",
        "scopeName": "text.harn.prompt",
        "path": "./syntaxes/harn-prompt.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "harn",
        "path": "./snippets/harn.json"
      }
    ],
    "commands": [
      {
        "command": "harn.runPipeline",
        "title": "Harn: Run Pipeline"
      },
      {
        "command": "harn.formatFile",
        "title": "Harn: Format File"
      },
      {
        "command": "harn.applyAllAutofixes",
        "title": "Harn: Apply All Autofixes"
      }
    ],
    "configurationDefaults": {
      "[harn]": {
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.fixAll.harn": "always"
        }
      }
    },
    "debuggers": [
      {
        "type": "harn",
        "label": "Harn",
        "languages": ["harn"],
        "configurationAttributes": {
          "launch": {
            "required": ["program"],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the .harn file to debug",
                "default": "${file}"
              },
              "cwd": {
                "type": "string",
                "description": "Working directory for the debug session",
                "default": "${workspaceFolder}"
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "harn",
            "request": "launch",
            "name": "Debug Current Harn File",
            "program": "${file}",
            "cwd": "${workspaceFolder}"
          }
        ]
      }
    ],
    "configuration": {
      "title": "Harn",
      "properties": {
        "harn.path": {
          "type": "string",
          "default": "harn",
          "description": "Path to the harn binary"
        },
        "harn.dapPath": {
          "type": "string",
          "default": "harn-dap",
          "description": "Path to the harn-dap debug adapter binary"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "typescript": "^6.0.2",
    "@vscode/vsce": "^3.7.1"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
