#!/bin/sh
set -e

echo "=== Pre-push: running fast release-quality checks ==="
make test
make fmt-harn

if command -v npx >/dev/null 2>&1; then
  npx markdownlint-cli2 "**/*.md"
fi

make lint-actions

if command -v npm >/dev/null 2>&1; then
  ./scripts/ensure_portal_deps.sh
  npm run portal:lint
fi

echo "=== Pre-push checks passed. ==="
