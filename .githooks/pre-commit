#!/bin/sh
set -e

echo "=== Pre-commit: checking formatting ==="
cargo fmt --all -- --check
echo "    Formatting OK."

echo "=== Pre-commit: checking harn formatting ==="
for f in conformance/tests/*.harn; do
  cargo run --quiet --bin harn -- fmt --check "$f"
done
echo "    Harn formatting OK."

echo "=== Pre-commit: running clippy ==="
cargo clippy --workspace -- -D warnings
echo "    Clippy OK."

if command -v npx >/dev/null 2>&1; then
  echo "=== Pre-commit: checking markdown ==="
  npx markdownlint-cli2 "**/*.md"
  echo "    Markdown OK."
else
  echo "=== Pre-commit: skipping markdown lint (npx not found) ==="
fi

echo "=== All pre-commit checks passed. ==="
