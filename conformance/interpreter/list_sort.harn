pipeline test(task) {
  let nums = [3, 1, 4, 1, 5, 9]
  log(nums.sort())
  log(nums.reverse())
  log([1, 2, 3].join(", "))
  log([1, 2, 3].contains(2))
  log([1, 2, 3].index_of(2))
  log([1, 2, 3, 2, 1].unique())
  log([1, 2, 3, 4, 5].take(3))
  log([1, 2, 3, 4, 5].skip(2))
  log([1, 2, 3, 4, 5].slice(1, 3))
  log([1, 2, 3].sum())
}
