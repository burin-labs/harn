pipeline test(task) {
  enum NetworkError {
    Timeout
  }
  enum AuthError {
    Unauthorized(msg)
  }

  // This typed catch only catches NetworkError — AuthError propagates
  try {
    try {
      throw AuthError.Unauthorized("bad token")
    } catch (e: NetworkError) {
      log("wrong handler — should not reach here")
    }
  } catch (e) {
    log("outer caught: ${e.variant}")
  }
}
