pipeline default() {
  enum Result {
    Ok(value)
    Err(message)
  }

  let val = Result.Ok(42)

  var output = ""
  match val {
    Result.Ok(v) -> { output = "got: " + to_string(v) }
    Result.Err(msg) -> { output = "error: " + msg }
  }
  println(output)

  let err = Result.Err("not found")
  var output2 = ""
  match err {
    Result.Ok(v) -> { output2 = "got: " + to_string(v) }
    Result.Err(msg) -> { output2 = "error: " + msg }
  }
  println(output2)
}
