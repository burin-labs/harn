pipeline default() {
  // Optional chaining on nil returns nil
  let x = nil
  println(x?.count)
  println(x?.name)
  // Optional chaining on non-nil works normally
  let d = {name: "Alice", age: 30}
  println(d?.name)
  println(d?.age)
  // Chained optional access
  let nested = {inner: {value: 42}}
  println(nested?.inner?.value)
  // Optional on list
  let items = [1, 2, 3]
  println(items?.count)
  println(items?.first)
  // Nil propagation through chain
  let empty = nil
  println(empty?.inner?.value)
  // Optional chaining on non-dict types returns nil for unknown props
  let n = 42
  println(n?.foo)
  let s = "hello"
  println(s?.count)
  println(s?.foo)
}
