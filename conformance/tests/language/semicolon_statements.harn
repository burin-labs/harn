fn first() {
  return "one"
}; fn second() {
  return "two"
}

skill deploy {
  description "Ship it"; prompt "Follow the runbook."
}

pipeline test(task) {
  let x = 1; let y = 2
  let meta = skill_find(deploy, "deploy")
  assert(first() == "one", "first function should parse on one line")
  assert(second() == "two", "second function should parse on one line")
  assert(x + y == 3, "semicolon should separate let bindings")
  assert(meta.prompt == "Follow the runbook.", "skill fields should accept semicolons")
  log("semicolon statements passed")
}
