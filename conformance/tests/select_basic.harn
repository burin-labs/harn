pipeline test(task) {
  let ch1 = channel("ch1")
  let ch2 = channel("ch2")

  // Send to ch2 first
  spawn {
    send(ch2, "from ch2")
  }

  // Small delay to ensure send completes
  sleep(50ms)

  select {
    msg from ch1 {
      log("ch1: ${msg}")
    }
    msg from ch2 {
      log("ch2: ${msg}")
    }
  }
}
