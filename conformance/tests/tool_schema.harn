pipeline default() {
  // Create registry with tools
  var tools = tool_registry()
  tools = tool_define(
    tools,
    "search",
    "Search the web",
    {
    handler: { query -> return "results for: " + query },
    params: {query: {type: "string", description: "Search query"}},
    returns: {type: "object", properties: {results: {type: "array"}}},
  },
  )
  tools = tool_define(
    tools,
    "calculate",
    "Evaluate math",
    {
    handler: { _expr -> return "42" },
    params: {
    expression: {type: "string", description: "Expression to evaluate"},
    precision: {type: "integer", description: "Optional decimal precision"},
  },
    returns: {type: "string"},
  },
  )
  // Test tool_schema generates OpenAPI-like schema
  let schema = tool_schema(tools)
  println(schema.schema_version)
  println(schema.tools.count())
  println(schema.tools[0].name)
  println(schema.tools[0].inputSchema["type"])
  println(schema.tools[0].outputSchema.type)
  // Test tool_parse_call with single tool call (always returns a list)
  let text = "I'll search for that. <tool_call>{\"name\": \"search\", \"arguments\": {\"query\": \"tokyo\"}}</tool_call>"
  let calls = tool_parse_call(text)
  println(calls.count())
  println(calls[0].name)
  println(calls[0].arguments.query)
  // Test tool_parse_call with no tool call
  let no_calls = tool_parse_call("Just regular text")
  println(no_calls.count())
  // Test tool_format_result
  let result = tool_format_result("search", "13.96 million people")
  println(result)
  println("tool_schema_ok")
}
