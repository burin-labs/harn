pipeline test(task) {
  let root = runtime_context()
  assert_eq(root.task_id, "task_root")
  assert_eq(root.parent_task_id, nil)
  assert_eq(root.root_task_id, "task_root")
  assert_eq(root.task_name, "root")
  assert_eq(root.cancelled, false)
  assert_eq(runtime_context_values(), {})
  assert_eq(runtime_context_set("tenant", "acme"), nil)
  assert_eq(runtime_context_get("tenant"), "acme")
  assert_eq(runtime_context_get("missing", "fallback"), "fallback")
  let handle = spawn {
    let child = task_current()
    assert_eq(child.task_id, "task_root:spawn:1")
    assert_eq(child.parent_task_id, "task_root")
    assert_eq(child.root_task_id, "task_root")
    assert_eq(child.task_name, "spawn")
    assert_eq(runtime_context_get("tenant"), "acme")
    runtime_context_set("tenant", "child")
    assert_eq(runtime_context_get("tenant"), "child")
    child.task_id
  }
  assert_eq(await(handle), "task_root:spawn:1")
  assert_eq(runtime_context_get("tenant"), "acme")
  let fanout = parallel 2 { i ->
    let ctx = runtime_context()
    assert_eq(ctx.parent_task_id, "task_root")
    assert_eq(ctx.root_task_id, "task_root")
    assert_eq(ctx.task_name, "parallel")
    assert_eq(ctx.task_group_id, "task_root:parallel:1")
    assert_eq(runtime_context_get("tenant"), "acme")
    ctx.task_id
  }
  assert_eq(fanout, ["task_root:parallel:1:0", "task_root:parallel:1:1"])
  assert_eq(runtime_context_clear("tenant"), "acme")
  assert_eq(runtime_context_get("tenant"), nil)
  log("runtime context ok")
}
