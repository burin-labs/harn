pipeline default() {
  let starts = atomic(0)
  let sup = supervisor_start(
    {
      name: "capped",
      strategy: "one_for_one",
      children: [
        {
          name: "bad-stream",
          kind: "connector_stream",
          restart: {mode: "on_failure", max_restarts: 1, window_ms: 1000, backoff_ms: 1},
          task: { _ctx ->
            atomic_add(starts, 1)
            throw "stream-failed"
          },
        },
      ],
    },
  )
  sleep(25ms)
  let state = supervisor_state(sup)
  println(atomic_get(starts))
  println(state.children[0].status)
  println(state.children[0].current_wait_reason)
  println(state.metrics.failed)
  println(state.metrics.suppressed)
}
