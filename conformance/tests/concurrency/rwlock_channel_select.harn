pipeline test(task) {
  let reader_a = sync_rwlock_acquire("doc", "read", 0)
  let reader_b = sync_rwlock_acquire("doc", "read", 0)
  assert(reader_a != nil)
  assert(reader_b != nil)
  assert_eq(sync_rwlock_acquire("doc", "write", 0), nil)
  assert_eq(sync_release(reader_a), true)
  assert_eq(sync_release(reader_b), true)
  let writer = sync_rwlock_acquire("doc", "write", 0)
  assert(writer != nil)
  assert_eq(sync_release(writer), true)
  let ch1 = channel("ch1")
  let ch2 = channel("ch2")
  spawn {
    sleep(10ms)
    send(ch2, "ready")
  }
  let selected = channel_select([ch1, ch2], 100)
  assert_eq(selected["index"], 1)
  assert_eq(selected["channel"], "ch2")
  assert_eq(selected["value"], "ready")
  assert_eq(channel_select([ch1], 0), nil)
  log("rwlock/select ok")
}
