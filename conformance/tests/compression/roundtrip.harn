pipeline test(task) {
  let text = "compression round trip: hello, Harn"
  let bytes = bytes_from_hex("000102fffefd")
  assert_eq(bytes_to_string(gzip_decode(gzip_encode(text))), text)
  assert_eq(bytes_to_hex(gzip_decode(gzip_encode(bytes, 9))), "000102fffefd")
  assert_eq(bytes_to_string(zstd_decode(zstd_encode(text))), text)
  assert_eq(bytes_to_hex(zstd_decode(zstd_encode(bytes, 1))), "000102fffefd")
  assert_eq(bytes_to_string(brotli_decode(brotli_encode(text))), text)
  assert_eq(bytes_to_hex(brotli_decode(brotli_encode(bytes, 4))), "000102fffefd")
  let tar_archive = tar_create(
    [
      {path: "docs/readme.txt", content: text, mode: 420},
      {path: "bin/run", content: bytes_from_string("echo hi\n"), mode: 493},
    ],
  )
  let tar_entries = tar_extract(tar_archive)
  assert_eq(len(tar_entries), 2)
  assert_eq(tar_entries[0].path, "docs/readme.txt")
  assert_eq(bytes_to_string(tar_entries[0].content), text)
  assert_eq(tar_entries[0].mode, 420)
  assert_eq(tar_entries[1].path, "bin/run")
  assert_eq(bytes_to_string(tar_entries[1].content), "echo hi\n")
  assert_eq(tar_entries[1].mode, 493)
  let zip_archive = zip_create([{path: "notes/a.txt", content: "alpha"}, {path: "raw/data.bin", content: bytes}])
  let zip_entries = zip_extract(zip_archive)
  assert_eq(len(zip_entries), 2)
  assert_eq(zip_entries[0].path, "notes/a.txt")
  assert_eq(bytes_to_string(zip_entries[0].content), "alpha")
  assert_eq(zip_entries[1].path, "raw/data.bin")
  assert_eq(bytes_to_hex(zip_entries[1].content), "000102fffefd")
  log("compression roundtrip ok")
}
