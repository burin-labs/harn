import "std/triggers"
import "../_common"

fn wait_for_log_line(log_path, needle) {
  var attempts = 0
  while attempts < 200 {
    if file_exists(log_path) {
      let log = exec("cat", log_path).stdout
      if contains(log, needle) {
        return true
      }
    }
    sleep(50ms)
    attempts = attempts + 1
  }
  return false
}

fn wait_for_exit(pid) {
  var attempts = 0
  while attempts < 100 {
    let probe = shell("kill -0 " + pid + " >/dev/null 2>&1")
    if !probe.success {
      return true
    }
    sleep(50ms)
    attempts = attempts + 1
  }
  return false
}

fn pass_when(event: TriggerEvent) -> bool {
  return true
}

fn local_handler(event: TriggerEvent) -> dict {
  return {handled: true, trace_id: event.trace_id}
}

fn failing_handler(event: TriggerEvent) -> any {
  throw "graph-fail:" + event.kind
}

fn action_graph_has_node(trace_id: string, kind: string) -> bool {
  let records: list<TriggerActionGraphEvent> = trigger_inspect_action_graph(trace_id)
  for entry in records {
    for node in entry?.payload?.observability?.action_graph_nodes ?? [] {
      if node?.trace_id == trace_id && node?.kind == kind {
        return true
      }
    }
  }
  return false
}

fn action_graph_has_edge(trace_id: string, kind: string) -> bool {
  let records: list<TriggerActionGraphEvent> = trigger_inspect_action_graph(trace_id)
  for entry in records {
    for edge in entry?.payload?.observability?.action_graph_edges ?? [] {
      if edge?.kind == kind {
        return true
      }
    }
  }
  return false
}

pipeline test(task) {
  let unique = to_string(to_int(timestamp())) + "-" + to_string(random_int(100000, 999999))
  let root = path_join(temp_dir(), "harn-action-graph-dispatcher-" + unique)
  mkdir(root)
  let port = random_int(20000, 45000)
  write_file(
    path_join(root, "receiver.harn"),
    "pipeline default(task) {\n  let envelope = json_parse(task)\n  println(json_stringify({trace_id: envelope.event.trace_id, target_agent: envelope.target_agent}))\n}\n",
  )
  let repo_root = exec("git", "rev-parse", "--show-toplevel").stdout.trim()
  let harn_bin = env_or("HARN_CONFORMANCE_HARN_BIN", resolve_harn_bin(repo_root))
  assert(file_exists(harn_bin), "missing built harn binary at " + harn_bin)
  let start = shell_at(
    root,
    "nohup " + harn_bin + " serve --port " + to_string(port)
      + " receiver.harn >receiver.log 2>&1 </dev/null & echo $!",
  )
  let pid = start.stdout.trim()
  assert(start.success, "failed to start A2A receiver")
  assert(pid != "", "missing A2A receiver pid")
  assert(
    wait_for_log_line(
      path_join(root, "receiver.log"),
      "Harn A2A server listening on http://localhost:" + to_string(port),
    ),
    "A2A receiver did not start",
  )
  let local_trace = "trace-graph-local-" + unique
  let worker_trace = "trace-graph-worker-" + unique
  let retry_trace = "trace-graph-retry-" + unique
  let a2a_trace = "trace-graph-a2a-" + unique
  let local_handle: TriggerHandle = trigger_register(
    {
      id: "graph-local-" + unique,
      kind: "issue.opened",
      provider: "github",
      handler: local_handler,
      when: pass_when,
      retry: nil,
      match: {events: ["issue.opened"]},
      events: nil,
      budget: nil,
      dedupe_key: nil,
      filter: nil,
      manifest_path: nil,
      package_name: "conformance",
    },
  )
  let worker_handle: TriggerHandle = trigger_register(
    {
      id: "graph-worker-" + unique,
      kind: "issue.opened",
      provider: "github",
      handler: "worker://graph-" + unique,
      when: nil,
      retry: nil,
      match: {events: ["issue.opened"]},
      events: nil,
      budget: nil,
      dedupe_key: nil,
      filter: nil,
      manifest_path: nil,
      package_name: "conformance",
    },
  )
  let retry_handle: TriggerHandle = trigger_register(
    {
      id: "graph-retry-" + unique,
      kind: "issue.opened",
      provider: "github",
      handler: failing_handler,
      when: nil,
      retry: {max: 2, backoff: "immediate"},
      match: {events: ["issue.opened"]},
      events: nil,
      budget: nil,
      dedupe_key: nil,
      filter: nil,
      manifest_path: nil,
      package_name: "conformance",
    },
  )
  let a2a_handle: TriggerHandle = trigger_register(
    {
      id: "graph-a2a-" + unique,
      kind: "issue.opened",
      provider: "github",
      handler: "a2a://127.0.0.1:" + to_string(port) + "/triage",
      allow_cleartext: true,
      when: nil,
      retry: {max: 1, backoff: "immediate"},
      match: {events: ["issue.opened"]},
      events: nil,
      budget: nil,
      dedupe_key: nil,
      filter: nil,
      manifest_path: nil,
      package_name: "conformance",
    },
  )
  let local_fire: DispatchHandle = trigger_fire(
    local_handle,
    {
      provider: "github",
      kind: "issue.opened",
      trace_id: local_trace,
      headers: {x_delivery: "evt-local-" + unique},
    },
  )
  let worker_fire: DispatchHandle = trigger_fire(
    worker_handle,
    {
      provider: "github",
      kind: "issue.opened",
      trace_id: worker_trace,
      headers: {x_delivery: "evt-worker-" + unique},
    },
  )
  let retry_fire: DispatchHandle = trigger_fire(
    retry_handle,
    {
      provider: "github",
      kind: "issue.opened",
      trace_id: retry_trace,
      headers: {x_delivery: "evt-retry-" + unique},
    },
  )
  let a2a_fire: DispatchHandle = trigger_fire(
    a2a_handle,
    {
      provider: "github",
      kind: "issue.opened",
      trace_id: a2a_trace,
      headers: {x_delivery: "evt-a2a-" + unique},
    },
  )
  let _ = shell("kill -TERM " + pid)
  wait_for_exit(pid)
  delete_file(root)
  println(local_fire.status == "dispatched" && worker_fire.status == "dispatched")
  println(retry_fire.status == "dlq" && contains(retry_fire.error ?? "", "graph-fail:issue.opened"))
  println(a2a_fire.status == "dispatched" && a2a_fire.result?.trace_id == a2a_trace)
  println(action_graph_has_node(local_trace, "trigger"))
  println(action_graph_has_node(local_trace, "predicate"))
  println(action_graph_has_node(local_trace, "dispatch"))
  println(action_graph_has_node(worker_trace, "worker_enqueue"))
  println(action_graph_has_node(retry_trace, "retry"))
  println(action_graph_has_node(retry_trace, "dlq"))
  println(action_graph_has_node(a2a_trace, "a2a_hop"))
  println(action_graph_has_edge(local_trace, "trigger_dispatch"))
  println(action_graph_has_edge(local_trace, "predicate_gate"))
  println(action_graph_has_edge(retry_trace, "retry"))
  println(action_graph_has_edge(retry_trace, "dlq_move"))
  println(action_graph_has_edge(a2a_trace, "a2a_dispatch"))
}
