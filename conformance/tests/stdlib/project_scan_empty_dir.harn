import "std/project"

pipeline test(task) {
  mkdir("project_scan_empty")

  let ev = project_scan("project_scan_empty", {tiers: ["ambient", "config"]})
  let tree = project_scan_tree("project_scan_empty", {tiers: ["ambient"], depth: 1})

  println(ev.path.ends_with("/project_scan_empty"))
  println(len(ev.languages) == 0)
  println(len(ev.frameworks) == 0)
  println(len(ev.build_systems) == 0)
  println(len(tree["."].languages) == 0)
}
