import "std/project"

pipeline test(task) {
  let namespace = "coding-enrichment-${uuid()}"
  let root = path_join(temp_dir(), "project-deep-scan-invalidation-" + uuid())
  mkdir(root)
  write_file(path_join(root, "README.md"), "# repo\n")
  llm_mock({text: "{\"purpose\":\"root\"}"})
  let first = project_deep_scan(
    root,
    {
    namespace: namespace,
    tiers: ["ambient", "config", "enriched"],
    incremental: true,
    depth: nil,
    enrichment: {
    prompt: "Return valid JSON only.",
    provider: "mock",
    schema: {purpose: "string"},
    budget_tokens_per_dir: 256,
  },
  },
  )
  write_file(path_join(root, "README.md"), "# repo changed\n")
  llm_mock({text: "{\"purpose\":\"root changed\"}"})
  let second = project_deep_scan(
    root,
    {
    namespace: namespace,
    tiers: ["ambient", "config", "enriched"],
    incremental: true,
    depth: nil,
    enrichment: {
    prompt: "Return valid JSON only.",
    provider: "mock",
    schema: {purpose: "string"},
    budget_tokens_per_dir: 256,
  },
  },
  )
  let second_status = project_deep_scan_status(namespace, root)
  println(first["."].enriched.purpose == "root")
  println(second["."].enriched.purpose == "root changed")
  println(second_status.cache_hits == 0)
  println(len(llm_mock_calls()) == 2)
  delete_file(root)
}
