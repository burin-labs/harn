pipeline test(task) {
  log(path_normalize("a/b/../c"))
  log(path_normalize("/a/b/../c"))
  log(path_normalize("a\\b\\c"))
  log(path_normalize("/"))
  log(path_parent("a/b/c.rs"))
  log(path_parent("/a/b"))
  log(path_basename("a/b/c.rs"))
  log(path_stem("a/b/c.rs"))
  log(path_extension("a/b/c.rs"))
  log(path_extension("a/b/c.tar.gz"))
  log(path_with_extension("a/b/c.rs", "txt"))
  log(path_with_extension("a/b/c.rs", ".txt"))
  log(path_with_stem("a/b/c.rs", "main"))
  log(path_is_absolute("/a/b"))
  log(path_is_absolute("C:/a"))
  log(path_is_absolute("a/b"))
  log(path_is_relative("a/b"))
  log(path_to_posix("a\\b\\c"))
  log(path_relative_to("/a/b/c", "/a/b"))
  log(path_relative_to("/a/c", "/a/b"))
  let parts = path_parts("src/main.rs")
  log(parts["dir"])
  log(parts["stem"])
  log(parts["ext"])
  log(parts["file"])
  log(len(path_segments("a/b/c")))

  let root = path_join(temp_dir(), "harn_stdlib_path_workspace")
  let nested = path_join(root, "packages/demo")
  mkdir(nested)
  write_file(path_join(nested, "file.txt"), "ok")
  let recovered = path_workspace_info("/packages/demo/file.txt", root)
  log(recovered.kind)
  log(recovered.workspace_path)
  log(recovered.recovered_root_drift)
  log(path_workspace_normalize("/packages/demo/file.txt", root))
  let absolute = path_workspace_info(path_join(root, "packages/demo/file.txt"), root)
  log(absolute.kind)
  log(absolute.workspace_path)
  let invalid = path_workspace_info("../secret.txt", root)
  log(invalid.kind)
  log(invalid.reason != nil)
  delete_file(root)
}
