import "std/project"

pipeline test(task) {
  let namespace = "coding-enrichment-${uuid()}"
  let root = path_join(temp_dir(), "project-deep-scan-cache-" + uuid())
  mkdir(root)
  write_file(path_join(root, "README.md"), "# repo\n")
  llm_mock({text: "{\"purpose\":\"root\"}"})
  let first = project_deep_scan(
    root,
    {
      namespace: namespace,
      tiers: ["ambient", "config", "enriched"],
      incremental: true,
      depth: nil,
      enrichment: {
        prompt: "Return valid JSON only.",
        provider: "mock",
        schema: {purpose: "string"},
        budget_tokens_per_dir: 256,
      },
    },
  )
  let calls = llm_mock_calls()
  println(len(keys(first)) == 1)
  println(first["."].enriched.purpose == "root")
  println(len(calls) == 1)
  println(contains(calls[0].messages[0].content, "Return valid JSON only."))
  let second = project_deep_scan(
    root,
    {
      namespace: namespace,
      tiers: ["ambient", "config", "enriched"],
      incremental: true,
      depth: nil,
      enrichment: {
        prompt: "Return valid JSON only.",
        provider: "mock",
        schema: {purpose: "string"},
        budget_tokens_per_dir: 256,
      },
    },
  )
  let second_status = project_deep_scan_status(namespace, root)
  println(second["."].enriched.purpose == "root")
  println(second_status.total_dirs == 1)
  println(second_status.cache_hits == 1)
  println(len(llm_mock_calls()) == 1)
  delete_file(root)
}
