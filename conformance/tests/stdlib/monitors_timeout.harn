import { wait_for } from "std/monitors"

pipeline test(task) {
  let result = wait_for(
    {
      wait_id: "conformance-monitor-timeout",
      timeout: 0ms,
      poll_interval: 5ms,
      source: {label: "conformance-timeout", poll: { _ -> return {ready: false} }},
      condition: { state -> state.ready },
    },
  )
  println(result.status == "timed_out")
  println(result.reason != nil)
}
