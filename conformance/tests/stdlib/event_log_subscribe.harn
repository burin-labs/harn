pipeline default() {
  let first_id = event_log.emit("tests.events", "one", {n: 1})
  let second_id = event_log.emit("tests.events", "two", {n: 2})
  let replay = event_log.subscribe({topic: "tests.events", from_cursor: first_id})
  let replayed = replay.next()
  println(replayed.value.kind)
  println(replayed.value.payload.n)
  let live = event_log.subscribe({topic: "tests.events", from_cursor: second_id})
  event_log.emit("tests.events", "three", {n: 3})
  let live_event = live.next()
  println(live_event.value.kind)
  println(live_event.value.cursor)
}
