pipeline test(task) {
  // base64 encode/decode
  let encoded = base64_encode("hello world")
  log(encoded)
  let decoded = base64_decode(encoded)
  log(decoded)
  let bytes = bytes_from_string("hello world")
  log(type_of(bytes))
  log(bytes_to_string(bytes))
  log(bytes_to_hex(bytes_from_hex("0001ff")))
  log(bytes_to_base64(bytes_from_string("hi")))
  log(bytes_to_string(bytes_from_base64("aGk=")))
  // sha256
  let hash = sha256("hello")
  log(hash)
  // md5
  let md = md5("hello")
  log(md)
}
