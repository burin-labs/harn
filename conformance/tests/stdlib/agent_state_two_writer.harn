import "std/agent_state"

pipeline default() {
  let root = path_join(temp_dir(), "harn-agent-state-two-writer-" + uuid())
  let first = agent_state_init(root, {session_id: "conflict-session", writer_id: "stage-a"})
  agent_state_write(first, "ledger.md", "from-a")
  let second = agent_state_resume(root, "conflict-session", {writer_id: "stage-b", conflict_policy: "ignore"})
  agent_state_write(second, "ledger.md", "from-b")
  println(agent_state_read(second, "ledger.md"))
  let strict = agent_state_resume(root, "conflict-session", {writer_id: "stage-c", conflict_policy: "error"})
  let message = try {
    agent_state_write(strict, "ledger.md", "from-c")
    "no error"
  } catch (e) {
    to_string(e)
  }
  println(contains(message, "previously written by"))
  println(contains(message, "stage-b") && contains(message, "stage-c"))
  println(agent_state_read(strict, "ledger.md"))
  delete_file(root)
}
