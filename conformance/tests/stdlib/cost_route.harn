import { llm_call_count } from "std/testing"

pipeline test(task) {
  llm_mock_clear()
  let routed = cost_route {
    budget_usd: 1.0
    prefer: ["mock:mock"]
    fallback_strategy: cheapest_first

    llm_call("hello route")
  }
  assert_eq(routed.provider, "mock")
  assert_eq(routed.model, "mock")
  assert_eq(llm_call_count(), 1)
  let explicit = cost_route {
    route_policy: "always(mock:mock)"

    llm_call("manual route", nil, {provider: "mock", model: "mock", route_policy: "manual"})
  }
  assert_eq(explicit.provider, "mock")
  assert_eq(explicit.model, "mock")
  assert_eq(llm_call_count(), 2)
  println("ok")
}
