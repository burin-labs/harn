pipeline test(task) {
  let parsed = cookie_parse("sid=abc; theme=light; sid=old; badsegment")
  assert_eq(parsed.cookies.sid, "abc")
  assert_eq(parsed.cookies.theme, "light")
  assert_eq(parsed.duplicates.sid[0], "abc")
  assert_eq(parsed.duplicates.sid[1], "old")
  assert_eq(len(parsed.invalid), 1)
  log("parsed")
  let serialized = cookie_serialize(
    "theme",
    "dark",
    {path: "/", max_age: 60, http_only: true, secure: true, same_site: "Strict"},
  )
  assert_eq(serialized, "theme=dark; Path=/; Max-Age=60; HttpOnly; Secure; SameSite=Strict")
  let deleted = cookie_delete("sid", {secure: false})
  assert(contains(deleted, "sid=; Path=/; Max-Age=0"))
  assert(contains(deleted, "Expires=Thu, 01 Jan 1970 00:00:00 GMT"))
  assert(contains(deleted, "HttpOnly"))
  assert(contains(deleted, "SameSite=Lax"))
  let bad_name = try {
    cookie_serialize("bad name", "value")
  }
  assert(is_err(bad_name))
  let bad_same_site = try {
    cookie_serialize("sid", "value", {same_site: "None"})
  }
  assert(is_err(bad_same_site))
  log("serialized")
  let signed = cookie_sign("plain-value", "secret")
  let verified = cookie_verify(signed, "secret")
  assert(verified.ok)
  assert_eq(verified.value, "plain-value")
  let forged = cookie_verify(signed + "x", "secret")
  assert(!forged.ok)
  assert_eq(forged.error, "invalid_signature")
  log("signed-cookie")
  let token = session_sign({user: "alice", roles: ["operator"]}, "secret")
  let session = session_verify(token, "secret")
  assert(session.ok)
  assert_eq(session.payload.user, "alice")
  assert_eq(session.payload.roles[0], "operator")
  let bad_session = session_verify(token + "x", "secret")
  assert(!bad_session.ok)
  assert_eq(bad_session.error, "invalid_signature")
  let set_cookie = session_cookie("harn_session", {user: "alice"}, "secret")
  assert(starts_with(set_cookie, "harn_session=v1."))
  assert(contains(set_cookie, "Path=/"))
  assert(contains(set_cookie, "HttpOnly"))
  assert(contains(set_cookie, "Secure"))
  assert(contains(set_cookie, "SameSite=Lax"))
  log("session")
  let round_trip = cookie_round_trip("sid=old; theme=light", [set_cookie, cookie_delete("sid", {secure: false})])
  assert_eq(round_trip.cookies.theme, "light")
  assert(round_trip.cookies.sid == nil)
  let from_cookie = session_from_cookies(round_trip.cookie_header, "harn_session", "secret")
  assert(from_cookie.ok)
  assert_eq(from_cookie.payload.user, "alice")
  log("round-trip")
}
