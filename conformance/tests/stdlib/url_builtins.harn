pipeline test(task) {
  let parts = url_parse("https://user:pass@api.example.com:8080/v1/items?q=hello&page=2#frag")
  log(parts["scheme"])
  log(parts["host"])
  log(parts["port"])
  log(parts["path"])
  log(parts["query"])
  log(parts["fragment"])
  log(parts["username"])
  let built = url_build({scheme: "https", host: "example.com", path: "/api", query: "x=1&y=2"})
  log(built)
  let pairs = query_parse("?key=alpha&key=beta&other=42")
  log(len(pairs))
  log(pairs[0]["key"])
  log(pairs[0]["value"])
  log(pairs[1]["value"])
  let qs = query_stringify([{key: "name", value: "ali ce"}, {key: "ids", value: "1,2,3"}])
  log(qs)
}
