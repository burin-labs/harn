import "std/project"

pipeline test(task) {
  let suffix = uuid()
  let alpha_namespace = "alpha-${suffix}"
  let beta_namespace = "beta-${suffix}"
  let root = path_join(temp_dir(), "project-deep-scan-ns-" + suffix)
  mkdir(root)
  write_file(path_join(root, "README.md"), "# repo\n")
  llm_mock({text: "{\"purpose\":\"alpha root\"}"})
  let alpha = project_deep_scan(
    root,
    {
    namespace: alpha_namespace,
    tiers: ["ambient", "enriched"],
    incremental: true,
    depth: nil,
    enrichment: {prompt: "Return valid JSON only.", provider: "mock", schema: {purpose: "string"}},
  },
  )
  llm_mock({text: "{\"purpose\":\"beta root\"}"})
  let beta = project_deep_scan(
    root,
    {
    namespace: beta_namespace,
    tiers: ["ambient", "enriched"],
    incremental: true,
    depth: nil,
    enrichment: {prompt: "Return valid JSON only.", provider: "mock", schema: {purpose: "string"}},
  },
  )
  let alpha_cached = project_deep_scan(
    root,
    {
    namespace: alpha_namespace,
    tiers: ["ambient", "enriched"],
    incremental: true,
    depth: nil,
    enrichment: {prompt: "Return valid JSON only.", provider: "mock", schema: {purpose: "string"}},
  },
  )
  let beta_cached = project_deep_scan(
    root,
    {
    namespace: beta_namespace,
    tiers: ["ambient", "enriched"],
    incremental: true,
    depth: nil,
    enrichment: {prompt: "Return valid JSON only.", provider: "mock", schema: {purpose: "string"}},
  },
  )
  println(alpha["."].enriched.purpose == "alpha root")
  println(beta["."].enriched.purpose == "beta root")
  println(alpha_cached["."].enriched.purpose == "alpha root")
  println(beta_cached["."].enriched.purpose == "beta root")
  println(project_deep_scan_status(alpha_namespace, root).cache_hits == 1)
  println(project_deep_scan_status(beta_namespace, root).cache_hits == 1)
  println(len(llm_mock_calls()) == 2)
  delete_file(root)
}
