pipeline test(task) {
  transport_mock_clear()
  let server = websocket_server("127.0.0.1:0", {})
  assert(websocket_route(server, "/acp", {idle_timeout_ms: 1000}))
  assert(websocket_route(server, "/secure", {auth: {bearer: "secret"}}))
  assert(websocket_route(server, "/limited", {max_message_bytes: 3}))
  assert(websocket_route(server, "/backpressure", {send_buffer_messages: 0}))
  let missing = try {
    websocket_connect(server.url + "/missing", {timeout_ms: 500})
  }
  assert(is_err(missing), "unregistered routes reject upgrades")
  let unauthorized = try {
    websocket_connect(server.url + "/secure", {timeout_ms: 500})
  }
  assert(is_err(unauthorized), "bearer route rejects missing auth")
  let secure_client = websocket_connect(server.url + "/secure", {timeout_ms: 500, auth: {bearer: "secret"}})
  let secure_server = websocket_accept(server, 1000)
  assert_eq(secure_server.path, "/secure")
  assert(websocket_close(secure_client))
  assert(websocket_close(secure_server))
  let client = websocket_connect(server.url + "/acp", {timeout_ms: 500})
  let conn = websocket_accept(server, 1000)
  assert_eq(conn.path, "/acp")
  assert(conn.headers["sec-websocket-key"] != nil)
  assert(websocket_send(client, "hello", {}))
  let text = websocket_receive(conn, 1000)
  assert_eq(text.type, "text")
  assert_eq(text.data, "hello")
  assert(websocket_send(conn, bytes_from_string("bin"), {}))
  let binary = websocket_receive(client, 1000)
  assert_eq(binary.type, "binary")
  assert_eq(binary.data_base64, "Ymlu")
  assert(websocket_send(client, "p", {type: "ping"}))
  let ping = websocket_receive(conn, 1000)
  assert_eq(ping.type, "ping")
  let auto_pong = websocket_receive(client, 1000)
  assert_eq(auto_pong.type, "pong")
  assert(websocket_send(client, "q", {type: "pong"}))
  let pong = websocket_receive(conn, 1000)
  assert_eq(pong.type, "pong")
  assert(websocket_send(conn, "", {type: "close", code: 1000, reason: "done"}))
  let closed = websocket_receive(client, 1000)
  assert_eq(closed.type, "close")
  assert_eq(closed.code, 1000)
  assert_eq(closed.reason, "done")
  let limited_client = websocket_connect(server.url + "/limited", {timeout_ms: 500})
  let limited_conn = websocket_accept(server, 1000)
  assert(websocket_send(limited_client, "toolong", {}))
  let limited = try {
    websocket_receive(limited_conn, 1000)
  }
  assert(is_err(limited), "server max_message_bytes rejects large frames")
  assert(websocket_close(limited_client))
  let backpressure_client = websocket_connect(server.url + "/backpressure", {timeout_ms: 500})
  let backpressure_conn = websocket_accept(server, 1000)
  let saturated = try {
    websocket_send(backpressure_conn, "blocked", {})
  }
  assert(is_err(saturated), "full outbound buffers reject sends")
  assert(websocket_close(backpressure_client))
  assert(websocket_close(backpressure_conn))
  assert(websocket_server_close(server))
  println("websocket_server_builtins_ok")
}
