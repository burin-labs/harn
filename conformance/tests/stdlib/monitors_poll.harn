import { wait_for } from "std/monitors"

pipeline test(task) {
  let result = wait_for(
    {
    wait_id: "conformance-monitor-poll",
    timeout: 1ms,
    poll_interval: 5ms,
    source: {label: "conformance-poll", poll: { _ -> return {ready: true} }},
    condition: { state -> state.ready },
  },
  )
  println(result.status == "matched")
  println(result.poll_count == 1)
}
