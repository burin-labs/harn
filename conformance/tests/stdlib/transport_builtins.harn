pipeline test(task) {
  http_mock_clear()
  transport_mock_clear()
  http_mock("GET", "https://api.example.test/session", {status: 200, body: "pooled", headers: {}})
  let session = http_session({timeout_ms: 100})
  let response = http_session_request(session, "GET", "https://api.example.test/session", {})
  assert_eq(response.status, 200)
  assert_eq(response.body, "pooled")
  assert(http_session_close(session))
  sse_mock("https://events.example.test/stream", [{event: "hello", data: "one", id: "1"}, "two"])
  let stream = sse_connect("GET", "https://events.example.test/stream", {})
  let opened = sse_receive(stream, 0)
  let first = sse_receive(stream, 0)
  let second = sse_receive(stream, 0)
  let done = sse_receive(stream, 0)
  assert_eq(opened.type, "open")
  assert_eq(first.type, "event")
  assert_eq(first.event, "hello")
  assert_eq(first.data, "one")
  assert_eq(second.data, "two")
  assert_eq(done, nil)
  websocket_mock("wss://socket.example.test/app", {messages: ["hello"], echo: true})
  let socket = websocket_connect("wss://socket.example.test/app", {})
  let greeting = websocket_receive(socket, 0)
  assert_eq(greeting.type, "text")
  assert_eq(greeting.data, "hello")
  assert(websocket_send(socket, "ack", {}))
  let echoed = websocket_receive(socket, 0)
  assert_eq(echoed.data, "ack")
  assert(websocket_close(socket))
  websocket_mock("wss://socket.example.test/limited", ["too-long"])
  let limited = websocket_connect("wss://socket.example.test/limited", {max_message_bytes: 3})
  let limit_result = try {
    websocket_receive(limited, 0)
  }
  assert(is_err(limit_result))
  assert(websocket_close(limited))
  assert_eq(len(transport_mock_calls()), 6)
  println("transport_builtins_ok")
}
