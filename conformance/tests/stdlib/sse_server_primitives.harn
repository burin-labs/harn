pipeline test(task) {
  let frame = sse_event({event: "progress", data: "one\ntwo", id: "evt-1", retry_ms: 2500})
  assert(contains(frame, "id: evt-1"))
  assert(contains(frame, "event: progress"))
  assert(contains(frame, "retry: 2500"))
  assert(contains(frame, "data: one\ndata: two"))
  let response = sse_server_response({max_event_bytes: 128, max_buffered_events: 2})
  assert_eq(response.status, 200)
  assert_eq(response.headers["content-type"], "text/event-stream; charset=utf-8")
  assert(sse_server_send(response, {event: "progress", data: "25", id: "1", retry: 1500}))
  assert(sse_server_heartbeat(response, "tick"))
  assert(sse_server_flush(response))
  let status = sse_server_status(response)
  assert_eq(status.buffered_events, 2)
  assert_eq(status.sent_events, 2)
  assert_eq(status.flushed_events, 2)
  assert_eq(status.disconnected, false)
  assert_eq(status.cancelled, false)
  let first = sse_server_mock_receive(response)
  assert_eq(first.type, "event")
  assert_eq(first.event, "progress")
  assert_eq(first.data, "25")
  assert_eq(first.id, "1")
  assert_eq(first.retry_ms, 1500)
  let beat = sse_server_mock_receive(response)
  assert_eq(beat.type, "comment")
  assert_eq(beat.comment, "tick")
  let timeout = sse_server_mock_receive(response)
  assert_eq(timeout.type, "timeout")
  let limited = sse_server_response({max_event_bytes: 10})
  let too_big = try {
    sse_server_send(limited, {data: "this is too large"})
  }
  assert(is_err(too_big))
  let disconnected = sse_server_response({})
  assert(sse_server_mock_disconnect(disconnected))
  assert(sse_server_disconnected(disconnected))
  assert_eq(sse_server_send(disconnected, "late"), false)
  let disconnected_close = sse_server_mock_receive(disconnected)
  assert_eq(disconnected_close.type, "close")
  let cancelled = sse_server_response({})
  assert(sse_server_cancel(cancelled, "stop"))
  assert(sse_server_cancelled(cancelled))
  assert_eq(sse_server_send(cancelled, "late"), false)
  let cancelled_status = sse_server_status(cancelled)
  assert_eq(cancelled_status.cancel_reason, "stop")
  let cancelled_close = sse_server_mock_receive(cancelled)
  assert_eq(cancelled_close.type, "close")
  assert(sse_server_close(response))
  assert_eq(sse_server_flush(response), false)
  println("sse_server_primitives_ok")
}
