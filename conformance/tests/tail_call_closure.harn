pipeline default() {
  // Tail call optimization with closures passed as arguments
  let double = { x -> x * 2 }
  let apply = { f, x -> f(x) }
  println(apply(double, 5))
  println(apply({ x -> x + 10 }, 3))
  // Pipe into closure
  let result = 7 |> { x -> x * 3 }
  println(result)
  // Chained pipes with closures
  let out = 2 |> { x -> x + 1 } |> { x -> x * 10 }
  println(out)
}
