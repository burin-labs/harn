import "std/math"

pipeline test(task) {
  assert_eq(dot([1, 2, 3], [4, 5, 6]), 32.0)
  assert_eq(vector_norm([3, 4]), 5.0)

  let unit = vector_normalize([3, 4])
  assert_eq(round(unit[0] * 10), 6)
  assert_eq(round(unit[1] * 10), 8)

  let cosine = cosine_similarity([1, 0], [1, 1])
  assert(cosine > 0.7071)
  assert(cosine < 0.7072)

  assert_eq(euclidean_distance([0, 0], [3, 4]), 5.0)
  assert_eq(manhattan_distance([1, 2], [4, 6]), 7.0)
  assert_eq(chebyshev_distance([1, 2], [4, 6]), 4.0)
  log("stdlib math vectors ok")
}
