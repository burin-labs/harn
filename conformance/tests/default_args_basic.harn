pipeline test(task) {
  fn greet(name, greeting = "hello") {
    log("${greeting}, ${name}!")
  }
  greet("world")
  greet("world", "hi")
  fn add(a, b = 10) {
    return a + b
  }
  log(add(5))
  log(add(5, 20))
  fn flag(x, enabled = true) {
    if enabled {
      log("on: ${x}")
    } else {
      log("off: ${x}")
    }
  }
  flag("test")
  flag("test", false)
}
