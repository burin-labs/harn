pipeline main(task) {
  let s = agent_session_open()
  assert(agent_session_exists(s), "open returns an id that exists")
  assert(s == agent_session_open(s), "open(id) is idempotent")
  assert(agent_session_length(s) == 0, "new session is empty")
  agent_session_inject(s, {role: "user", content: "hello"})
  agent_session_inject(s, {role: "assistant", content: "hi"})
  assert(agent_session_length(s) == 2, "inject appends")
  let snap = agent_session_snapshot(s)
  assert(len(snap["messages"]) == 2, "snapshot mirrors transcript")
  assert(snap["id"] == s, "snapshot preserves id")
  agent_session_reset(s)
  assert(agent_session_length(s) == 0, "reset clears history")
  assert(agent_session_exists(s), "reset preserves id")
  agent_session_inject(s, {role: "user", content: "one"})
  agent_session_inject(s, {role: "user", content: "two"})
  agent_session_inject(s, {role: "user", content: "three"})
  let kept = agent_session_trim(s, 2)
  assert(kept == 2, "trim returns kept count")
  let after = agent_session_snapshot(s)
  assert(after["messages"][0]["content"] == "two", "trim drops oldest")
  assert(after["messages"][1]["content"] == "three", "trim retains newest")
  agent_session_close(s)
  assert(!agent_session_exists(s), "close evicts")
  log("agent_sessions basic tests passed")
}
