// `try*` rethrows the original thrown value with its original type, so
// a typed-catch filter on the outer `try { ... } catch (e: T) { ... }`
// applies to the rethrown value normally.
pipeline test(task) {
  enum AppError {
    NotFound(msg)
  }
  fn find_missing() {
    throw AppError.NotFound("user")
  }
  let matched: string = try {
    let _ = try* find_missing()
    "unreachable"
  } catch (e: AppError) {
    "typed:${e.variant}"
  }
  log("matched: ${matched}")
}
