// Test that date_parse validates month/day ranges
pipeline default(task) {
  // Valid date should work
  let ts = date_parse("2024-06-15")
  println(ts > 0)
  // Invalid month
  let r1 = try {
    date_parse("2024-13-01")
  }
  println(is_err(r1))
  // Invalid day
  let r2 = try {
    date_parse("2024-01-32")
  }
  println(is_err(r2))
}
