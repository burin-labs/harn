fn identity(x) {
  return x
}

fn double(x) {
  return x * 2
}

fn add(a, b) {
  return a + b
}

fn concat3(a, b, c) {
  return a + "|" + b + "|" + c
}

fn make_dict(v) {
  return {key: v}
}

pipeline test(task) {
  // Simple nested call
  log(identity(identity(42)))
  // Result of one call passed as arg to another
  log(add(double(3), double(4)))
  // Three args with nested calls in each slot
  log(concat3(identity("a"), identity("b"), identity("c")))
  // Mixed: literal, nested call, nested call
  log(concat3("lit", identity("mid"), concat3("x", "y", "z")))
  // Nested call returning a dict used as arg
  let merged = make_dict(identity("val"))
  log(merged["key"])
  // Nested with ?? inside call args (regression for precedence bug)
  let name = nil
  log(concat3("base", name ?? "fallback", identity(name ?? "tag")))
}
