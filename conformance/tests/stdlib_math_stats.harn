import "std/math"

pipeline test(task) {
  assert_eq(mean([2, 4, 6]), 4)
  assert_eq(median([7, 1, 5]), 5)
  assert_eq(median([1, 2, 10, 20]), 6)
  assert_eq(percentile([1, 2, 3, 4], 25), 1.75)
  assert_eq(percentile([1, 2, 3, 4], 50), 2.5)
  assert_eq(variance([1, 2, 3, 4]), 1.25)
  assert_eq(round(stddev([1, 2, 3, 4]) * 1000), 1118)
  assert_eq(round(variance([1, 2, 3, 4], true) * 1000), 1667)
  assert_eq(round(stddev([1, 2, 3, 4], true) * 1000), 1291)
  assert_eq(argsort([30, 10, 20]), [1, 2, 0])
  assert_eq(argsort(["bbb", "a", "cc"], { x -> len(x) }), [1, 2, 0])
  assert_eq(top_k([10, 40, 20, 30], 2), [40, 30])
  assert_eq(top_k(["bbb", "a", "cc"], 2, { x -> len(x) }), ["bbb", "cc"])
  assert_eq(top_k([1, 2, 3], 0), [])
  assert_eq(minmax_scale([10, 20, 30]), [0.0, 0.5, 1.0])
  assert_eq(minmax_scale([5, 5, 5]), [0.0, 0.0, 0.0])
  let zs = zscore([1, 2, 3])
  assert(round(zs[0] * 1000) == -1225)
  assert(round(zs[1] * 1000) == 0)
  assert(round(zs[2] * 1000) == 1225)
  assert_eq(zscore([7, 7, 7]), [0.0, 0.0, 0.0])
  assert_eq(weighted_mean([10, 20, 30], [1, 2, 3]), 140 / 6.0)
  assert_eq(weighted_choice(["a", "b", "c"], [0, 1, 0]), "b")
  let probs = softmax([1, 2, 3])
  assert(round(sum(probs) * 1000) == 1000)
  assert(probs[2] > probs[1])
  assert(probs[1] > probs[0])
  assert_eq(moving_avg([1, 2, 3, 4, 5], 3), [2.0, 3.0, 4.0])
  let smoothed = ema([10, 20, 30], 0.5)
  assert_eq(smoothed[0], 10.0)
  assert_eq(smoothed[1], 15.0)
  assert_eq(smoothed[2], 22.5)
  assert_eq(covariance([1, 2, 3], [2, 4, 6]), 4 / 3.0)
  assert_eq(correlation([1, 2, 3], [2, 4, 6]), 1.0)
  log("stdlib math stats ok")
}
