pipeline default() {
  // Connect to the test MCP echo server
  let root = exec("git", "rev-parse", "--show-toplevel").stdout.trim()
  let server_path = root + "/conformance/helpers/mcp_echo_server.py"
  let client = mcp_connect("python3", [server_path])
  // Check type
  println(type_of(client))
  // List tools
  let tools = mcp_list_tools(client)
  println(tools.count)
  // Get tool names
  for t in tools {
    println(t.name)
  }
  // Call echo tool
  let result = mcp_call(client, "echo", {message: "hello from harn"})
  println(result)
  // Call add tool
  let sum = mcp_call(client, "add", {a: 3, b: 7})
  println(sum)
  // Server info
  let info = mcp_server_info(client)
  println(info.connected)
  // Disconnect
  mcp_disconnect(client)
}
