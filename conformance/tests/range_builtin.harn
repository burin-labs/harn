pipeline test(task) {
  // range(n) is half-open, 0-indexed
  let xs = range(5)
  log(xs)
  // range(a, b) is half-open
  let ys = range(3, 7)
  log(ys)
  // works in iteration with sum
  var total = 0
  for i in range(10) {
    total += i
  }
  log(total)
  // empty when b <= a
  log(len(range(5, 5)))
  log(len(range(0)))
}
