import "../_common"

pipeline default(task) {
  let unique = uuid()
  let root = path_join(temp_dir(), "harn-worker-enqueue-drain-" + unique)
  let producer_dir = path_join(root, "producer")
  let consumer_dir = path_join(root, "consumer")
  let state_dir = path_join(root, "state")
  mkdir(root)
  mkdir(producer_dir)
  mkdir(consumer_dir)
  mkdir(state_dir)
  write_file(
    path_join(producer_dir, "harn.toml"),
    "[package]\nname = \"worker-producer\"\n\n[[triggers]]\nid = \"incoming-review-task\"\nkind = \"a2a-push\"\nprovider = \"a2a-push\"\nmatch = { events = [\"a2a.task.received\"] }\nhandler = \"worker://triage\"\npriority = \"high\"\n",
  )
  write_file(
    path_join(consumer_dir, "harn.toml"),
    "[package]\nname = \"worker-consumer\"\n\n[exports]\nhandlers = \"lib.harn\"\n\n[[triggers]]\nid = \"incoming-review-task\"\nkind = \"a2a-push\"\nprovider = \"a2a-push\"\nmatch = { events = [\"a2a.task.received\"] }\nhandler = \"handlers::on_task\"\n",
  )
  write_file(
    path_join(consumer_dir, "lib.harn"),
    "import \"std/triggers\"\n\npub fn on_task(event: TriggerEvent) -> dict {\n  return {ok: true, kind: event.kind, event_id: event.id}\n}\n",
  )
  let repo_root = exec("git", "rev-parse", "--show-toplevel").stdout.trim()
  let harn_bin = env_or("HARN_CONFORMANCE_HARN_BIN", resolve_harn_bin(repo_root))
  assert(file_exists(harn_bin), "missing built harn binary at " + harn_bin)
  let fire = exec(
    harn_bin,
    "orchestrator",
    "fire",
    "incoming-review-task",
    "--config",
    path_join(producer_dir, "harn.toml"),
    "--state-dir",
    state_dir,
  )
  let queue_before = exec(
    harn_bin,
    "orchestrator",
    "queue",
    "--config",
    path_join(consumer_dir, "harn.toml"),
    "--state-dir",
    state_dir,
    "ls",
    "--json",
  )
  let before = json_parse(queue_before.stdout)
  println(
    fire.success
    && contains(fire.stdout, "\"queue\":\"triage\"")
    && queue_before.success
    && before.worker_queues[0].queue == "triage"
    && before.worker_queues[0].ready == 1,
  )
  let drain = exec(
    harn_bin,
    "orchestrator",
    "queue",
    "--config",
    path_join(consumer_dir, "harn.toml"),
    "--state-dir",
    state_dir,
    "drain",
    "triage",
    "--consumer-id",
    "consumer-a",
    "--json",
  )
  let data = json_parse(drain.stdout)
  println(drain.success && data.drained == 1 && data.acked == 1 && data.deferred == 0)
  println(data.summary.ready == 0 && data.summary.in_flight == 0 && data.summary.responses == 1)
  println(data.responses[0].outcome?.status == "succeeded" && data.responses[0].error == nil)
}
