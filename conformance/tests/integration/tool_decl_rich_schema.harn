pipeline test(task) {
  tool create_user(user: {name: string, age?: int}, tags: list<string>, prefs: dict<string, int>) -> {ok: bool, names: list<string>} {
    return {ok: user.name != "" && prefs["missing"] == nil, names: tags}
  }
  let tool_def = tool_find(create_user, "create_user")
  println(tool_def.parameters.user.type)
  println(tool_def.parameters.user.properties.name.type)
  println(tool_def.parameters.user.required[0])
  println(tool_def.parameters.tags.items.type)
  println(tool_def.parameters.prefs.additionalProperties.type)
  println(tool_def.outputSchema.properties.ok.type)
  println(tool_def.outputSchema.properties.names.items.type)
}
