/** Test tool registry builtins */
pipeline default(task) {
  // Create registry
  var tools = tool_registry()
  println(type_of(tools))
  println(tool_count(tools))
  // tool_define
  tools = tool_define(
    tools,
    "greet",
    "Say hello",
    {
      handler: { args -> "hi " + args.name },
      parameters: {name: {type: "string", description: "Name to greet"}},
      returns: {type: "string"},
    },
  )
  tools = tool_define(
    tools,
    "add",
    "Add numbers",
    {
      handler: { args -> args.a + args.b },
      parameters: {
        a: {type: "integer", description: "First operand"},
        b: {type: "integer", description: "Second operand"},
      },
      returns: {type: "integer"},
    },
  )
  println(tool_count(tools))
  // tool_list
  let list = tool_list(tools)
  println(len(list))
  // tool_find
  let found = tool_find(tools, "greet")
  println(found != nil)
  let missing = tool_find(tools, "nonexistent")
  println(missing == nil)
  let selected = tool_select(tools, ["add"])
  println(tool_count(selected))
  println(tool_find(selected, "add") != nil)
  println(tool_find(selected, "greet") == nil)
  // tool_remove
  let smaller = tool_remove(tools, "add")
  println(tool_count(smaller))
  // tool_describe
  let desc = tool_describe(tools)
  println(contains(desc, "greet"))
  println(contains(desc, "add"))
  // tool_schema
  let schema = tool_schema(tools)
  println(schema.schema_version)
  println(len(schema.tools))
  // tool_parse_call
  let calls = tool_parse_call(
    "<tool_call>{\"name\": \"greet\", \"arguments\": {\"name\": \"world\"}}</tool_call>",
  )
  println(len(calls))
  println(calls[0].name)
  // tool_format_result
  let result = tool_format_result("greet", "hello")
  println(contains(result, "tool_result"))
  println(contains(result, "greet"))
  // tool_prompt
  let prompt = tool_prompt(tools)
  println(contains(prompt, "Available Tools"))
  println(contains(prompt, "greet"))
}
