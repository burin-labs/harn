import "std/triggers"

fn handler(event: TriggerEvent) -> dict {
  return {handled: true, kind: event.kind}
}

fn classify(event: TriggerEvent) -> bool {
  let result = llm_call(
    "predicate false " + event.kind,
    nil,
    {provider: "mock", model: "gpt-4o-mini", llm_retries: 0},
  )
  return contains(result.text, "yes")
}

pipeline test(task) {
  llm_mock_clear()
  llm_mock({text: "no", input_tokens: 10, output_tokens: 5, model: "gpt-4o-mini"})

  let unique = to_string(to_int(timestamp())) + "-" + to_string(random_int(100000, 999999))
  let handle: TriggerHandle = trigger_register({
    id: "llm-predicate-false-" + unique,
    kind: "issue.opened",
    provider: "github",
    handler: handler,
    when: classify,
    when_budget: nil,
    retry: nil,
    match: {events: ["issue.opened"]},
    events: nil,
    dedupe_key: nil,
    filter: nil,
    budget: nil,
    manifest_path: nil,
    package_name: nil,
  })

  let fire: DispatchHandle = trigger_fire(
    handle,
    {provider: "github", kind: "issue.opened", headers: {x_delivery: "evt-false-" + unique}},
  )
  let dispatches = trigger_inspect_lifecycle("DispatchStarted").filter(
    { entry -> entry?.headers?.trigger_id == handle.id },
  )

  println(fire.status == "dispatched")
  println(contains(json_stringify(fire.result ?? {}), "\"skipped\":true"))
  println(contains(json_stringify(fire.result ?? {}), "\"reason\":null"))
  println(len(dispatches) == 0)
}
