pipeline test(task) {
  // Trig
  let p = pi()
  assert(p > 3.14)
  assert(p < 3.15)
  assert_eq(sin(0), 0.0)
  assert_eq(cos(0), 1.0)
  assert_eq(tan(0), 0.0)
  // Inverse trig
  assert_eq(asin(0), 0.0)
  assert_eq(acos(1), 0.0)
  assert_eq(atan(0), 0.0)
  // atan2
  let a = atan2(1, 1)
  assert(a > 0.78)
  assert(a < 0.79)
  // Logarithms
  assert_eq(ln(1), 0.0)
  let l2 = log2(8)
  assert_eq(l2, 3.0)
  let l10 = log10(100)
  assert_eq(l10, 2.0)
  // exp
  let e_val = e()
  assert(e_val > 2.71)
  assert(e_val < 2.72)
  assert_eq(exp(0), 1.0)
  // sign
  assert_eq(sign(42), 1)
  assert_eq(sign(-5), -1)
  assert_eq(sign(0), 0)
  assert_eq(sign(3.14), 1)
  assert_eq(sign(-2.5), -1)
  // is_nan, is_infinite
  assert(!is_nan(1.0))
  assert(!is_infinite(1.0))
  log("math ok")
}
