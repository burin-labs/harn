pipeline default() {
  fn count_down(n, acc) {
    if n <= 0 {
      return acc
    }
    return count_down(n - 1, acc + 1)
  }
  fn sum_tail(n, acc) {
    if n <= 0 {
      return acc
    }
    return sum_tail(n - 1, acc + n)
  }
  // This would overflow the 512-frame stack without TCO
  let result = count_down(10000, 0)
  println(result)
  // Tail-recursive sum
  let total = sum_tail(100, 0)
  println(total)
}
