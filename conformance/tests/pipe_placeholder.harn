pipeline default() {
  // Basic pipe placeholder
  let result = "hello world" |> split(_, " ")
  println(result)
  // Chained with placeholder
  let n = "hello world"
    |> split(_, " ")
    |> len(_)
  println(n)
  // Placeholder in second arg
  let msg = "world" |> replace("hello _", "_", _)
  println(msg)
  // Placeholder with method call
  let nums = [3, 1, 2] |> _.sort()
  println(nums)
}
