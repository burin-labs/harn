fn child_tools() {
  var tools = tool_registry()
  tools = tool_define(
    tools,
    "search",
    "Search the repo",
    {
      handler: { args -> "search result for " + args.query },
      parameters: {query: {type: "string"}},
      returns: {type: "string"},
    },
  )
  tools = tool_define(
    tools,
    "read",
    "Read a file",
    {
      handler: { args -> "file contents from " + args.path },
      parameters: {path: {type: "string"}},
      returns: {type: "string"},
    },
  )
  return tools
}

fn parent_tools() {
  var tools = tool_registry()
  tools = tool_define(
    tools,
    "delegate",
    "Run a sub-agent",
    {
      handler: { args -> sub_agent_run(
        args.task,
        {
          provider: "mock",
          tools: child_tools(),
          allowed_tools: ["search", "read"],
          tool_format: "native",
          max_iterations: 3,
        },
      ) },
      parameters: {task: {type: "string"}},
      returns: {type: "object"},
    },
  )
  return tools
}

pipeline main() {
  llm_mock(
    {tool_calls: [{id: "parent_1", name: "delegate", arguments: {task: "Find the config path"}}]},
  )
  llm_mock({tool_calls: [{id: "child_1", name: "search", arguments: {query: "config path"}}]})
  llm_mock(
    {tool_calls: [{id: "child_2", name: "read", arguments: {path: "crates/harn-vm/src/lib.rs"}}]},
  )
  llm_mock({text: "The config path is crates/harn-vm/src/lib.rs"})
  llm_mock({text: "Delegation complete."})
  let result = agent_loop(
    "Investigate the config path",
    "You are helpful.",
    {provider: "mock", tools: parent_tools(), tool_format: "native", max_iterations: 2},
  )
  let stats = transcript_stats(result?.transcript)
  let transcript = json_stringify(transcript_messages(result?.transcript))
  println(stats?.tool_call_count == 1)
  println(stats?.tool_result_message_count == 1)
  println(contains(transcript, "delegate"))
  println(!contains(transcript, "\"search\""))
  println(!contains(transcript, "\"read\""))
}
