pipeline main() {
  let base = transcript({source: "conformance"})
  let with_asset = transcript_add_asset(
    base,
    {
    kind: "image",
    name: "diagram.png",
    mime_type: "image/png",
    storage: {path: ".harn/assets/diagram.png"},
  },
  )
  let asset_id = transcript_assets(with_asset)[0].id
  let multimodal = add_user(
    with_asset,
    [
    {type: "image", asset_id: asset_id, name: "diagram.png", visibility: "public"},
    {type: "text", text: "review this diagram", visibility: "public"},
  ],
  )
  println(len(transcript_assets(multimodal)) == 1)
  println(transcript_messages(multimodal)[0].content[0].asset_id == asset_id)
  println(contains(transcript_render_visible(multimodal), "diagram.png"))
  let forked = transcript_fork(multimodal)
  println(len(transcript_assets(forked)) == 1)
  let imported = transcript_import(transcript_export(multimodal))
  let imported_assets = transcript_assets(imported)
  println(len(imported_assets) == 1)
}
