import "std/triggers"

fn ok_handler(event: TriggerEvent) -> dict {
  return {binding: "ok-trigger", kind: event.kind, provider: event.provider}
}

fn ok_when(event: TriggerEvent) -> bool {
  return event.kind == "issue.opened"
}

fn fail_handler(event: TriggerEvent) -> any {
  throw "dlq:" + event.kind
}

pipeline test(task) {
  let unique = to_string(to_int(timestamp())) + "-" + to_string(random_int(100000, 999999))
  let ok_id = "ok-trigger-" + unique
  let fail_id = "fail-trigger-" + unique
  let ok_config: TriggerConfig = {
    id: ok_id,
    kind: "issue.opened",
    provider: "github",
    handler: ok_handler,
    when: ok_when,
    when_budget: nil,
    retry: nil,
    match: {events: ["issue.opened"]},
    events: nil,
    budget: {daily_cost_usd: 1.25, max_concurrent: 2},
    dedupe_key: "event.id",
    filter: "event.kind == issue.opened",
    manifest_path: "runtime://trigger-stdlib",
    package_name: "conformance",
  }
  let fail_config: TriggerConfig = {
    id: fail_id,
    kind: "issue.opened",
    provider: "github",
    handler: fail_handler,
    retry: {max: 1, backoff: "immediate"},
    events: ["issue.opened"],
    when: nil,
    when_budget: nil,
    match: nil,
    dedupe_key: nil,
    filter: nil,
    budget: nil,
    manifest_path: nil,
    package_name: nil,
  }
  let ok_handle: TriggerHandle = trigger_register(ok_config)
  let fail_handle: TriggerHandle = trigger_register(fail_config)
  println(ok_handle.id == ok_id && ok_handle.state == "active")
  println(fail_handle.id == fail_id && fail_handle.handler_kind == "local")
  let bindings: list<TriggerBinding> = trigger_list()
  let listed_ok = bindings.find({ binding -> binding.id == ok_handle.id })
  println(len(bindings) == 2 && listed_ok?.provider == "github")
  println(listed_ok?.metrics?.received == 0)
  let ok_fire: DispatchHandle = trigger_fire(
    ok_handle,
    {provider: "github", kind: "issue.opened", headers: {x_delivery: "evt-success"}},
  )
  println(ok_fire.status == "dispatched" && ok_fire.error == nil)
  println(contains(json_stringify(ok_fire.result ?? {}), "\"kind\":\"issue.opened\""))
  let fail_fire: DispatchHandle = trigger_fire(
    fail_handle,
    {provider: "github", kind: "issue.opened", headers: {x_delivery: "evt-dlq"}},
  )
  println(fail_fire.status == "dlq" && contains(fail_fire.error ?? "", "dlq:issue.opened"))
  let dlq_before: list<DlqEntry> = trigger_inspect_dlq()
  let current_dlq_before = dlq_before.filter({ entry -> entry.binding_id == fail_handle.id })
  println(len(current_dlq_before) == 1 && current_dlq_before[0].event_id == fail_fire.event_id)
  println(len(current_dlq_before[0].retry_history) == 1)
  println(current_dlq_before[0].event.provider == "github")
  let replay: DispatchHandle = trigger_replay(fail_fire.event_id)
  println(replay.status == "dlq" && replay.replay_of_event_id == fail_fire.event_id)
  let dlq_after: list<DlqEntry> = trigger_inspect_dlq()
  let current_dlq_after = dlq_after.filter({ entry -> entry.binding_id == fail_handle.id })
  println(len(current_dlq_after) == 1 && len(current_dlq_after[0].retry_history) == 2)
  println(current_dlq_after[0].retry_history[1].status == "replay_dlq")
  let bindings_after: list<TriggerBinding> = trigger_list()
  let live_fail = bindings_after.find({ binding -> binding.id == fail_handle.id })
  println(live_fail?.metrics?.dlq == 2)
}
