import "std/triggers"

pipeline test(task) {
  let providers: list<ProviderCatalogEntry> = list_providers()
  let builtin = providers.filter({ provider -> provider.runtime.kind == "builtin" })
  assert(len(builtin) == 6, "expected exactly six builtin trigger providers")
  let stream_providers = providers.filter({ provider -> provider.kinds.any({ kind -> kind == "stream" }) })
  assert(len(stream_providers) == 6, "expected six stream trigger providers")
  assert(
    stream_providers.all({ provider -> provider.schema_name == "StreamEventPayload" }),
    "stream providers should publish the shared stream payload schema",
  )
  assert(
    stream_providers.all({ provider -> provider.runtime.kind == "placeholder" }),
    "stream providers should be cataloged before concrete connector activation lands",
  )
  assert(
    stream_providers.any({ provider -> provider.provider == "kafka" })
    && stream_providers.any({ provider -> provider.provider == "nats" })
    && stream_providers.any({ provider -> provider.provider == "pulsar" })
    && stream_providers.any({ provider -> provider.provider == "postgres-cdc" })
    && stream_providers.any({ provider -> provider.provider == "email" })
    && stream_providers.any({ provider -> provider.provider == "websocket" }),
    "catalog should include every STREAM-01 provider",
  )
  let cron = builtin.find({ provider -> provider.provider == "cron" })
  assert(cron?.schema_name == "CronEventPayload", "cron schema should be cataloged")
  assert(cron?.runtime?.connector == "cron", "cron should use the cron connector")
  assert(
    cron?.signature_verification?.kind == "none",
    "cron should not require signature verification",
  )
  assert(len(cron?.secret_requirements ?? []) == 0, "cron should not require secrets")
  assert(len(cron?.outbound_methods ?? []) == 0, "cron should not publish outbound methods yet")
  let webhook = builtin.find({ provider -> provider.provider == "webhook" })
  assert(webhook?.schema_name == "GenericWebhookPayload", "webhook schema should be cataloged")
  assert(webhook?.runtime?.connector == "webhook", "webhook should use the webhook connector")
  assert(
    webhook?.runtime?.default_signature_variant == "standard",
    "webhook should default to standard signatures",
  )
  assert(
    webhook?.signature_verification?.kind == "hmac",
    "webhook should publish HMAC verification metadata",
  )
  assert(
    webhook?.signature_verification?.variant == "standard",
    "webhook should publish the standard variant",
  )
  assert(
    webhook?.signature_verification?.signature_header == "webhook-signature",
    "webhook should expose the signature header",
  )
  assert(
    webhook?.signature_verification?.timestamp_header == "webhook-timestamp",
    "webhook should expose the timestamp header",
  )
  let webhook_secrets = webhook?.secret_requirements ?? []
  assert(len(webhook_secrets) == 1, "webhook should require one secret")
  let webhook_secret = webhook_secrets[0]
  assert(webhook_secret.name == "signing_secret", "webhook should require signing_secret")
  assert(webhook_secret.namespace == "webhook", "webhook secrets should stay namespaced to webhook")
  let github = builtin.find({ provider -> provider.provider == "github" })
  assert(github?.schema_name == "GitHubEventPayload", "github schema should be cataloged")
  assert(
    github?.runtime?.connector == "webhook",
    "github should currently reuse the webhook connector transport",
  )
  assert(
    github?.runtime?.default_signature_variant == "github",
    "github should default to GitHub signatures",
  )
  assert(
    github?.signature_verification?.kind == "hmac",
    "github should publish HMAC verification metadata",
  )
  assert(
    github?.signature_verification?.variant == "github",
    "github should publish the github signature variant",
  )
  assert(
    github?.signature_verification?.signature_header == "X-Hub-Signature-256",
    "github should expose the signature header",
  )
  assert(
    github?.signature_verification?.id_header == "X-GitHub-Delivery",
    "github should expose the delivery header",
  )
  let github_secrets = github?.secret_requirements ?? []
  assert(len(github_secrets) == 1, "github should require one secret")
  let github_secret = github_secrets[0]
  assert(github_secret.name == "signing_secret", "github should require signing_secret")
  assert(github_secret.namespace == "github", "github secrets should stay namespaced to github")
  assert(len(github?.outbound_methods ?? []) == 0, "github should not publish outbound methods yet")
  let slack = builtin.find({ provider -> provider.provider == "slack" })
  assert(slack?.schema_name == "SlackEventPayload", "slack schema should be cataloged")
  assert(slack?.runtime?.connector == "slack", "slack should use the slack connector")
  assert(
    slack?.runtime?.default_signature_variant == "slack",
    "slack should default to slack signatures",
  )
  assert(
    slack?.signature_verification?.kind == "hmac",
    "slack should publish HMAC verification metadata",
  )
  assert(
    slack?.signature_verification?.variant == "slack",
    "slack should publish the slack signature variant",
  )
  assert(
    slack?.signature_verification?.signature_header == "X-Slack-Signature",
    "slack should expose the signature header",
  )
  assert(
    slack?.signature_verification?.timestamp_header == "X-Slack-Request-Timestamp",
    "slack should expose the timestamp header",
  )
  let slack_secrets = slack?.secret_requirements ?? []
  assert(len(slack_secrets) == 1, "slack should require one secret")
  let slack_secret = slack_secrets[0]
  assert(slack_secret.name == "signing_secret", "slack should require signing_secret")
  assert(slack_secret.namespace == "slack", "slack secrets should stay namespaced to slack")
  let slack_methods = slack?.outbound_methods ?? []
  assert(len(slack_methods) == 7, "slack should publish its outbound method surface")
  assert(slack_methods[0].name == "post_message", "slack should expose post_message")
  assert(slack_methods[3].name == "open_view", "slack should expose open_view")
  assert(slack_methods[4].name == "user_info", "slack should expose user_info")
  assert(slack_methods[5].name == "api_call", "slack should expose api_call")
  let linear = builtin.find({ provider -> provider.provider == "linear" })
  assert(linear?.schema_name == "LinearEventPayload", "linear schema should be cataloged")
  assert(linear?.runtime?.connector == "linear", "linear should use the native linear connector")
  assert(
    linear?.runtime?.default_signature_variant == "linear",
    "linear should default to linear signatures",
  )
  assert(
    linear?.signature_verification?.kind == "hmac",
    "linear should publish HMAC verification metadata",
  )
  assert(
    linear?.signature_verification?.signature_header == "Linear-Signature",
    "linear should expose the signature header",
  )
  assert(
    linear?.signature_verification?.default_tolerance_secs == 75,
    "linear should publish the default replay tolerance",
  )
  let linear_secrets = linear?.secret_requirements ?? []
  assert(
    len(linear_secrets) == 2,
    "linear should publish signing + outbound auth secret requirements",
  )
  assert(
    linear_secrets.any({ requirement -> requirement.name == "signing_secret" && requirement.required }),
    "linear should require signing_secret",
  )
  assert(
    linear_secrets.any({ requirement -> requirement.name == "access_token" && !requirement.required }),
    "linear should optionally document access_token",
  )
  let linear_methods = linear?.outbound_methods ?? []
  assert(len(linear_methods) == 5, "linear should publish its outbound helper methods")
  assert(
    linear_methods.any({ method -> method.name == "graphql" }),
    "linear should publish the graphql escape hatch",
  )
  let notion = builtin.find({ provider -> provider.provider == "notion" })
  assert(notion?.schema_name == "NotionEventPayload", "notion schema should be cataloged")
  assert(notion?.runtime?.connector == "notion", "notion should use the notion connector")
  assert(
    notion?.runtime?.default_signature_variant == "notion",
    "notion should default to notion webhook signatures",
  )
  assert(
    notion?.signature_verification?.kind == "hmac",
    "notion should publish HMAC verification metadata",
  )
  assert(
    notion?.signature_verification?.variant == "notion",
    "notion should publish the notion signature variant",
  )
  assert(
    notion?.signature_verification?.signature_header == "X-Notion-Signature",
    "notion should expose the signature header",
  )
  let notion_secrets = notion?.secret_requirements ?? []
  assert(len(notion_secrets) == 1, "notion should publish its webhook verification secret")
  assert(
    notion_secrets
    .any(
    { secret -> secret.name == "verification_token" && secret.namespace == "notion" },
  ),
    "notion should require verification_token in the notion namespace",
  )
  let notion_methods = notion?.outbound_methods ?? []
  assert(len(notion_methods) == 7, "notion should publish seven outbound methods")
  assert(notion_methods.any({ method -> method.name == "get_page" }), "notion should expose get_page")
  assert(
    notion_methods.any({ method -> method.name == "update_page" }),
    "notion should expose update_page",
  )
  assert(
    notion_methods.any({ method -> method.name == "append_blocks" }),
    "notion should expose append_blocks",
  )
  assert(
    notion_methods.any({ method -> method.name == "query_database" }),
    "notion should expose query_database",
  )
  assert(notion_methods.any({ method -> method.name == "search" }), "notion should expose search")
  assert(
    notion_methods.any({ method -> method.name == "create_comment" }),
    "notion should expose create_comment",
  )
  assert(notion_methods.any({ method -> method.name == "api_call" }), "notion should expose api_call")
  log("trigger_provider_catalog tests passed")
}
