pipeline test(task) {
  gen fn broken() -> Stream<int> {
    emit 1
    throw "stream failed"
  }
  let stream = broken()
  let first = stream.next()
  println(first.value)
  try {
    stream.next()
  } catch (err) {
    println("caught ${err}")
  }
  let final = stream.next()
  println(final.done)
}
