// Test new string methods
pipeline default(task) {
  // trim_start / trim_end — verify by measuring length
  let s = "  hello world  "
  println(len(s.trim_start()))
  println(len(s.trim_end()))
  println(len(s.trim()))
  // lines
  let multi = "line1\nline2\nline3"
  let lines = multi.lines()
  println(len(lines))
  println(lines.first())
  println(lines.last())
  // char_at
  let word = "hello"
  println(word.char_at(0))
  println(word.char_at(4))
  println(word.char_at(99))
  // last_index_of
  let path = "src/lib/utils/lib.rs"
  println(path.index_of("lib"))
  println(path.last_index_of("lib"))
  // len method (on string)
  println("cafe".len())
}
