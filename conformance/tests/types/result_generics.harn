pipeline test(task) {
  fn divide(a: int, b: int) -> Result<int, string> {
    if b == 0 {
      return Result.Err("division by zero")
    }
    return Result.Ok(a / b)
  }
  fn halve_division(a: int, b: int) -> Result<int, string> {
    let value: int = divide(a, b)?
    return Result.Ok(value / 2)
  }
  let ok: Result<int, string> = halve_division(12, 3)
  let err: Result<int, string> = halve_division(12, 0)
  log(ok)
  log(err)
  match ok {
    Result.Ok(value) -> { log("ok: ${value}") }
    Result.Err(message) -> { log("err: ${message}") }
  }
}
