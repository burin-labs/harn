pipeline test(task) {
  // Typed function should work with correct types
  fn add(a: int, b: int) -> int {
    return a + b
  }
  assert_eq(add(2, 3), 5)
  // Float coercion is allowed for int params
  fn double(x: float) -> float {
    return x * 2
  }
  assert_eq(double(5), 10.0)
  // String param
  fn greet(name: string) -> string {
    return "hi " + name
  }
  assert_eq(greet("world"), "hi world")
  log("type checks ok")
}
