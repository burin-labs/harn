// Test "did you mean" suggestions on shape validation errors
pipeline default(task) {
  fn process(data: {name: string, email: string}) {
    println(data.name)
  }
  // Pass boundary data with typo: "emial" instead of "email"
  let bad = json_parse("{\"name\":\"test\",\"emial\":\"foo@bar.com\"}")
  let result = try {
    process(bad)
  }
  println(is_err(result))
  // The error should mention "email" as a suggestion
  let msg = unwrap_err(result)
  println(contains(msg, "email"))
}
