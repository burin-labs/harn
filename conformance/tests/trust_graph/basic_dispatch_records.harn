import "std/triggers"

fn handle_issue(event: TriggerEvent) -> dict {
  let context = handler_context()
  return {
    agent: context?.agent,
    action: context?.action,
    autonomy_tier: context?.autonomy_tier,
    trace_id: context?.trace_id,
    event_kind: event.kind,
  }
}

pipeline test(task) {
  let unique = to_string(to_int(timestamp())) + "-" + to_string(random_int(100000, 999999))
  let agent_id = "github-triage-bot-" + unique
  let handle: TriggerHandle = trigger_register({
    id: agent_id,
    kind: "issue.opened",
    provider: "github",
    autonomy_tier: "act_auto",
    handler: handle_issue,
    when: nil,
    retry: nil,
    match: {events: ["issue.opened"]},
    events: nil,
    dedupe_key: nil,
    filter: nil,
    budget: nil,
    manifest_path: "runtime://trust-graph",
    package_name: "conformance",
  })
  let fired: DispatchHandle = trigger_fire(
    handle,
    {provider: "github", kind: "issue.opened", headers: {x_delivery: "evt-" + unique}},
  )
  let records: list<TrustRecord> = trust_query({
    agent: agent_id,
    action: "github.issue.opened",
  })

  println(fired.status == "dispatched" && fired.error == nil)
  println(fired.result?.agent == agent_id)
  println(fired.result?.action == "github.issue.opened")
  println(fired.result?.autonomy_tier == "act_auto")
  println(len(records) == 1)
  println(records[0].schema == "opentrustgraph/v0")
  println(records[0].outcome == "success" && records[0].autonomy_tier == "act_auto")
  println(records[0].trace_id == fired.result?.trace_id)
}
