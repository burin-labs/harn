import "std/triggers"

fn gated_handler(event: TriggerEvent) -> dict {
  let context = handler_context()
  let file_path = path_join(".harn", "trust_graph_shadow_" + context?.agent ?? "unknown" + ".txt")
  write_file(file_path, "approved:" + event.kind)
  return {autonomy_tier: context?.autonomy_tier, file_path: file_path}
}

pipeline test(task) {
  let unique = to_string(to_int(timestamp())) + "-" + to_string(random_int(100000, 999999))
  let agent_id = "shadow-bot-" + unique
  let file_path = path_join(".harn", "trust_graph_shadow_" + agent_id + ".txt")
  mkdir(".harn")
  let handle: TriggerHandle = trigger_register(
    {
    id: agent_id,
    kind: "issue.opened",
    provider: "github",
    autonomy_tier: "shadow",
    handler: gated_handler,
    when: nil,
    retry: nil,
    match: {events: ["issue.opened"]},
    events: nil,
    dedupe_key: nil,
    filter: nil,
    budget: nil,
    manifest_path: "runtime://trust-graph",
    package_name: "conformance",
  },
  )
  let first: DispatchHandle = trigger_fire(
    handle,
    {provider: "github", kind: "issue.opened", headers: {x_delivery: "evt-shadow-" + unique}},
  )
  let denied: list<TrustRecord> = trust_query({agent: agent_id, action: "github.issue.opened", outcome: "denied"})
  let file_after_first = file_exists(file_path)
  let promoted: TrustRecord = trust_record(agent_id, "trust.promote", "tester", "success", "act_auto")
  let promote_records: list<TrustRecord> = trust_query({agent: agent_id, action: "trust.promote"})
  let second: DispatchHandle = trigger_fire(
    handle,
    {provider: "github", kind: "issue.opened", headers: {x_delivery: "evt-auto-" + unique}},
  )
  let successes: list<TrustRecord> = trust_query({agent: agent_id, action: "github.issue.opened", outcome: "success"})
  println(first.status == "failed")
  println(!file_after_first)
  println(len(denied) == 1 && denied[0].autonomy_tier == "shadow")
  println(promoted.action == "trust.promote" && promoted.autonomy_tier == "act_auto")
  println(len(promote_records) == 1)
  println(second.status == "dispatched" && second.error == nil)
  println(second.result?.autonomy_tier == "act_auto")
  println(file_exists(file_path))
  delete_file(file_path)
  println(len(successes) == 1 && successes[0].autonomy_tier == "act_auto")
}
