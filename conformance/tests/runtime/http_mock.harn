pipeline test(task) {
  // Mock HTTP framework
  // Register a mock for GET requests
  http_mock(
    "GET",
    "https://api.example.com/users",
    {status: 200, body: "{\"users\": [\"alice\", \"bob\"]}", headers: {}},
  )
  // Register a mock for POST with glob pattern
  http_mock("POST", "https://api.example.com/*", {status: 201, body: "{\"created\": true}"})
  // Make a GET request - should hit mock
  let resp = http_get("https://api.example.com/users")
  assert_eq(resp.status, 200)
  log("get status: " + to_string(resp.status))
  let data = json_parse(resp.body)
  assert_eq(len(data.users), 2)
  log("users: " + to_string(len(data.users)))
  // Make a POST request - should hit glob mock
  let post_resp = http_post("https://api.example.com/items", "{\"name\": \"test\"}")
  assert_eq(post_resp.status, 201)
  log("post status: " + to_string(post_resp.status))
  // Check recorded calls
  let calls = http_mock_calls()
  assert_eq(len(calls), 2)
  assert_eq(calls[0].method, "GET")
  assert_eq(calls[1].method, "POST")
  log("calls: " + to_string(len(calls)))
  // Clear mocks
  http_mock_clear()
  let cleared = http_mock_calls()
  assert_eq(len(cleared), 0)
  log("cleared")
}
