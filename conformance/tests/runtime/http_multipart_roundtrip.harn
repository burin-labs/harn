pipeline default() {
  http_mock("POST", "https://api.example.com/upload", {status: 201, body: "uploaded", headers: {}})
  let response = http_post(
    "https://api.example.com/upload",
    {
      multipart: [
        {name: "meta", value: "hello"},
        {name: "blob", filename: "blob.txt", content_type: "text/plain", value: "payload"},
      ],
    },
  )
  let calls = http_mock_calls()
  let body = calls[0].body ?? ""
  println(response.status)
  println(calls[0].headers["content-type"])
  println(contains(body, "name=\"meta\""))
  println(contains(body, "hello"))
  println(contains(body, "filename=\"blob.txt\""))
}
