pipeline test(task) {
  log(iter([1, 2, 3, 4]).count())
  log(iter([1, 2, 3, 4]).sum())
  log(iter([3, 1, 4, 1, 5]).min())
  log(iter([3, 1, 4, 1, 5]).max())
  log(iter([1, 2, 3, 4]).reduce(0, { acc, x -> acc + x }))
  log(iter([10, 20, 30]).first())
  log(iter([10, 20, 30]).last())
  log(iter([]).first())
  log(iter([]).last())
  log(iter([]).min())
  log(iter([]).sum())
  log(iter([1, 2, 3]).any({ x -> x > 2 }))
  log(iter([1, 2, 3]).any({ x -> x > 99 }))
  log(iter([1, 2, 3]).all({ x -> x > 0 }))
  log(iter([1, 2, 3]).all({ x -> x > 1 }))
  log(iter([1, 2, 3, 4]).find({ x -> x > 2 }))
  log(iter([1, 2, 3]).find({ x -> x > 99 }))
  iter([1, 2, 3]).for_each({ x -> log("v=${x}") })
  log(iter([1, 1, 2, 2, 3]).to_set())
  let d = iter([pair("a", 1), pair("b", 2)]).to_dict()
  log(d.a)
  log(d.b)
}
