pipeline test(task) {
  // .first() and .last() on an inclusive range
  let inc = 1 to 5
  log(inc.first())
  log(inc.last())
  // .first() and .last() on an exclusive range
  let exc = 0 to 5 exclusive
  log(exc.first())
  log(exc.last())
  // Empty ranges — first/last return nil
  let empty = 5 to 1
  log(empty.first())
  log(empty.last())
  log(empty.len())
  // .contains(x) is O(1)
  log(inc.contains(3))
  log(inc.contains(5))
  log(inc.contains(6))
  log(exc.contains(0))
  log(exc.contains(5))
  // .to_list() materializes on demand
  log((1 to 4).to_list())
  log((0 to 3 exclusive).to_list())
}
